# Environment Variables for FIQ Supply Chain Control Tower
# Copy this file to .env.local (ignored by git) and fill in the values.

# Google Gemini API Key (required for AI analyst and CSV classification features)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Legacy support (for development)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Airtable Personal Access Token (required for base selector + AI-routed CSV upload)
# Generate at: https://airtable.com/create/tokens
# Required scopes: schema.bases:read, schema.tables:read, schema.tables:write,
#                  data.records:read, data.records:write
VITE_AIRTABLE_API_KEY=YOUR_AIRTABLE_PAT_HERE

# Optional: pre-select a specific Airtable base on load (base ID from Airtable URL)
# If omitted, the app lists all accessible bases in the dropdown.
VITE_AIRTABLE_BASE_ID=YOUR_BASE_ID_HERE
